                <div class="relative z-10 max-w-2xl space-y-4">
                    <span class="bg-emerald-500/30 text-emerald-200 text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider border border-emerald-400/20">Teknologi Untuk Umat</span>
                    <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight tracking-tight">Optimasi Penyaluran Zakat Menggunakan Kecerdasan Buatan</h1>
                    <p class="text-emerald-100 text-sm sm:text-base leading-relaxed">
                        SmartZakat AI menjembatani muzakki (pemberi) dan mustahik (penerima) secara lebih presisi, adil, dan transparan. Hitung zakat Anda dan analisis kelayakan penerima bantuan dengan algoritma sosial-ekonomi cerdas.
                    </p>
                    <div class="pt-4 flex flex-wrap gap-3">
                        <button onclick="switchTab('calculator')" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold px-5 py-3 rounded-xl transition shadow-lg shadow-amber-500/20 text-sm">
                            <i class="fa-solid fa-wallet mr-2"></i>Hitung Zakat Sekarang
                        </button>
                        <button onclick="switchTab('analyzer')" class="bg-emerald-600/80 hover:bg-emerald-600 text-white font-semibold px-5 py-3 rounded-xl border border-emerald-500/30 transition text-sm">
                            <i class="fa-solid fa-search-plus mr-2"></i>Analisis Mustahik AI
                        </button>
                    </div>
                </div>
            </div>

            <!-- Stats & Quick Actions Overview -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                <!-- Card 1 -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                    <div class="bg-emerald-50 p-4 rounded-xl text-emerald-600">
                        <i class="fa-solid fa-rupiah-sign text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-xs font-semibold text-slate-400 uppercase">Total Simulasi Penyaluran</p>
                        <p class="text-xl font-bold text-slate-800" id="stat-total-dana">Rp 45.250.000</p>
                    </div>
                </div>
                <!-- Card 2 -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                    <div class="bg-amber-50 p-4 rounded-xl text-amber-500">
                        <i class="fa-solid fa-users text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-xs font-semibold text-slate-400 uppercase">Mustahik Teranalisis AI</p>
                        <p class="text-xl font-bold text-slate-800" id="stat-total-mustahik">4 Calon</p>
                    </div>
                </div>
                <!-- Card 3 -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
                    <div class="bg-blue-50 p-4 rounded-xl text-blue-500">
                        <i class="fa-solid fa-brain text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-xs font-semibold text-slate-400 uppercase">Akurasi Verifikasi Asnaf</p>
                        <p class="text-xl font-bold text-slate-800">98.4% (Gemini)</p>
                    </div>
                </div>
            </div>

            <!-- Active Mustahik Showcase -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 space-y-6">
                <div class="flex justify-between items-center flex-wrap gap-2">
                    <div>
                        <h2 class="text-lg font-bold text-slate-800">Hasil Pemindaian Kelayakan Mustahik Terbaru</h2>
                        <p class="text-xs text-slate-400">Data hasil input sosial-ekonomi yang telah dievaluasi AI</p>
                    </div>
                    <button onclick="switchTab('analyzer')" class="text-emerald-600 hover:text-emerald-700 text-xs font-bold flex items-center">
                        Tambah Analisis Baru <i class="fa-solid fa-arrow-right ml-1.5"></i>
                    </button>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="mustahik-showcase-container">
