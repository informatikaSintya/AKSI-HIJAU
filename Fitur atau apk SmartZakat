                </div>
            </div>
        </section>

        <!-- ==================== TAB 2: KALKULATOR ZAKAT ==================== -->
        <section id="tab-calculator" class="hidden space-y-8 animate-fade-in">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                <!-- Calculator Inputs (8 Cols) -->
                <div class="lg:col-span-7 bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-slate-100 space-y-6">
                    <div>
                        <h2 class="text-xl font-bold text-slate-800 flex items-center">
                            <span class="bg-emerald-100 text-emerald-700 p-2 rounded-lg mr-3"><i class="fa-solid fa-calculator"></i></span>
                            Kalkulator Syariah Cerdas
                        </h2>
                        <p class="text-xs text-slate-400 mt-1">Pilih jenis zakat dan masukkan nilai aset Anda untuk perhitungan instan.</p>
                    </div>

                    <!-- Type Selector -->
                    <div class="grid grid-cols-3 gap-2">
                        <button onclick="setZakatType('maal')" id="btn-z-maal" class="border-2 border-emerald-500 bg-emerald-50 text-emerald-800 py-3 px-2 rounded-xl text-xs font-bold text-center flex flex-col items-center justify-center space-y-1 transition-all">
                            <i class="fa-solid fa-box-archive text-lg"></i>
                            <span>Zakat Maal</span>
                        </button>
                        <button onclick="setZakatType('pendapatan')" id="btn-z-pendapatan" class="border border-slate-200 hover:border-emerald-300 text-slate-600 py-3 px-2 rounded-xl text-xs font-semibold text-center flex flex-col items-center justify-center space-y-1 transition-all">
                            <i class="fa-solid fa-wallet text-lg"></i>
                            <span>Pendapatan</span>
                        </button>
                        <button onclick="setZakatType('fitrah')" id="btn-z-fitrah" class="border border-slate-200 hover:border-emerald-300 text-slate-600 py-3 px-2 rounded-xl text-xs font-semibold text-center flex flex-col items-center justify-center space-y-1 transition-all">
                            <i class="fa-solid fa-bowl-rice text-lg"></i>
                            <span>Zakat Fitrah</span>
                        </button>
                    </div>

                    <!-- Dynamic Forms -->
                    <div id="form-z-maal" class="space-y-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Nilai Emas, Perak, atau Uang Tunai/Tabungan (Rp)</label>
                            <input type="number" id="maal-harta" placeholder="Contoh: 100000000" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Harga Emas Saat Ini Per Gram (Rp)</label>
                            <input type="number" id="maal-harga-emas" value="1200000" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all">
                            <p class="text-[10px] text-slate-400 mt-1">Nisab Zakat Maal setara 85 Gram Emas murni.</p>
                        </div>
                    </div>

                    <div id="form-z-pendapatan" class="hidden space-y-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Penghasilan Bulanan (Rp)</label>
                            <input type="number" id="pend-bulanan" placeholder="Contoh: 15000000" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Pendapatan Lain / Bonus (Rp)</label>
                            <input type="number" id="pend-lain" value="0" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all">
                        </div>
                    </div>

                    <div id="form-z-fitrah" class="hidden space-y-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Jumlah Anggota Keluarga (Jiwa)</label>
                            <input type="number" id="fitrah-jiwa" value="1" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Harga Beras Konsumsi Per Kg (Rp)</label>
                            <input type="number" id="fitrah-harga-beras" value="15000" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all">
                            <p class="text-[10px] text-slate-400 mt-1">Zakat Fitrah per jiwa adalah 2.5 kg atau 3.5 liter beras berkualitas setara makanan pokok harian.</p>
                        </div>
                    </div>

                    <!-- Action Trigger -->
                    <div class="pt-2">
                        <button onclick="calculateZakat()" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 px-4 rounded-xl transition shadow-lg shadow-emerald-600/10 flex items-center justify-center space-x-2">
                            <i class="fa-solid fa-calculator"></i>
                            <span>Proses Perhitungan</span>
                        </button>
                    </div>
                </div>

                <!-- Live Results & AI Explanation (5 Cols) -->
                <div class="lg:col-span-5 flex flex-col space-y-6">
                    <!-- Math Output -->
                    <div class="bg-gradient-to-br from-slate-900 to-emerald-950 text-white p-6 sm:p-8 rounded-2xl shadow-xl flex flex-col justify-between min-h-[220px]">
                        <div>
                            <span class="bg-emerald-500/20 text-emerald-400 text-[10px] font-bold px-2.5 py-1 rounded-full uppercase border border-emerald-400/20">Jumlah Wajib Zakat</span>
                            <h3 class="text-3xl font-black mt-3 text-emerald-400" id="res-zakat-amount">Rp 0</h3>
                            <div class="mt-4 space-y-1.5 border-t border-slate-800 pt-4 text-xs text-slate-300">
                                <div class="flex justify-between"><span class="text-slate-400">Status Wajib:</span> <span id="res-zakat-status" class="font-bold text-amber-400">Belum dihitung</span></div>
                                <div class="flex justify-between"><span class="text-slate-400">Nisab Acuan:</span> <span id="res-zakat-nisab">Rp 0</span></div>
                            </div>
                        </div>
                        <div class="pt-4 flex items-center justify-between text-[11px] text-slate-400">
