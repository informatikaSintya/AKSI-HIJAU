                    <span class="text-xs font-semibold text-slate-500 bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">Gemini 2.5 Active</span>
                </div>
            </div>
        </div>
    </header>

    <!-- MOBILE NAVIGATION BOTTOM BAR -->
    <div class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-slate-200 z-50 px-4 py-2 shadow-lg">
        <div class="grid grid-cols-4 gap-1">
            <button onclick="switchTab('dashboard')" id="mob-dashboard" class="flex flex-col items-center justify-center py-1 text-emerald-600">
                <i class="fa-solid fa-chart-line text-lg"></i>
                <span class="text-[10px] mt-1 font-medium">Beranda</span>
            </button>
            <button onclick="switchTab('calculator')" id="mob-calculator" class="flex flex-col items-center justify-center py-1 text-slate-400">
                <i class="fa-solid fa-calculator text-lg"></i>
                <span class="text-[10px] mt-1 font-medium">Kalkulator</span>
            </button>
            <button onclick="switchTab('analyzer')" id="mob-analyzer" class="flex flex-col items-center justify-center py-1 text-slate-400">
                <i class="fa-solid fa-user-shield text-lg"></i>
                <span class="text-[10px] mt-1 font-medium">Mustahik</span>
            </button>
            <button onclick="switchTab('chatbot')" id="mob-chatbot" class="flex flex-col items-center justify-center py-1 text-slate-400">
                <i class="fa-solid fa-robot text-lg"></i>
