                        </div>
                    </div>

                    <!-- AI Explanation -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex-grow flex flex-col">
                        <div class="flex items-center space-x-2 pb-4 border-b border-slate-100">
                            <div class="bg-amber-100 text-amber-700 p-1.5 rounded-lg text-xs"><i class="fa-solid fa-microchip"></i></div>
                            <h4 class="text-xs font-bold text-slate-700 uppercase tracking-wide">Penjelasan Fikih & Syarat AI</h4>
                        </div>
                        <div class="flex-grow py-4 flex flex-col justify-center items-center text-center text-slate-400" id="calc-ai-loader">
                            <i class="fa-solid fa-brain text-3xl mb-2 text-slate-300 animate-pulse"></i>
                            <p class="text-xs max-w-xs">Silakan lakukan perhitungan untuk melihat penjelasan rinci dari AI.</p>
                        </div>
                        <div class="hidden text-slate-600 text-xs leading-relaxed space-y-3 overflow-y-auto max-h-[280px] pr-2" id="calc-ai-response">
                            <!-- Dynamic Content -->
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ==================== TAB 3: MUSTAHIK ANALYZER ==================== -->
        <section id="tab-analyzer" class="hidden space-y-8 animate-fade-in">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                <!-- Form Mustahik (7 Cols)
